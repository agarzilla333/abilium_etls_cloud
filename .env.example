# Abilium ETL — environment template.
# Copy to .env and fill in. .env is gitignored; never commit real secrets.
# In Cloud Run these come from Terraform env vars + Secret Manager, not a file.

# ─── Shopify ─────────────────────────────────────────────────────────────────
# Cross-org setup: one Dev Dashboard app per client store, custom-distributed to
# that store. Tokens are PERMANENT OFFLINE tokens captured once via OAuth
# (GET /oauth/install?client=<key> -> /oauth/callback), NOT static custom-app
# tokens (those were retired Jan 2026) and NOT client_credentials (cross-org).
#
# Client ID + Secret per app — used only during OAuth capture:
SHOPIFY_CLIENT_ID_ENLIGHTENED_BABY=
SHOPIFY_CLIENT_SECRET_ENLIGHTENED_BABY=
SHOPIFY_CLIENT_ID_KINDRED_SPIRITS=
SHOPIFY_CLIENT_SECRET_KINDRED_SPIRITS=
SHOPIFY_CLIENT_ID_KICK_PLEAT=
SHOPIFY_CLIENT_SECRET_KICK_PLEAT=
#
# Offline tokens (filled in automatically by /oauth/callback, or paste manually).
# These are what the runtime uses. Scope: read_reports + Level-2 protected
# customer data. Store domains/api_version live in config/clients.json.
SHOPIFY_TOKEN_ENLIGHTENED_BABY=
SHOPIFY_TOKEN_KINDRED_SPIRITS=
SHOPIFY_TOKEN_KICK_PLEAT=

# Base URL where this service is reachable for the OAuth redirect. Must match the
# app's "Allowed redirection URL(s)" (= APP_BASE_URL + /oauth/callback). Local
# capture needs a public tunnel (e.g. cloudflared) or the deployed Cloud Run URL.
APP_BASE_URL=

# ─── Google Cloud / Sheets + Drive ───────────────────────────────────────────
# Project id — used to read Shopify tokens from Secret Manager when the env
# overrides above are absent (i.e. in deployed mode).
GCP_PROJECT=

# Local auth for Sheets/Drive. Easiest: run
#   gcloud auth application-default login
# (as a user with access to the Shared Drive) and leave this unset.
# Or point at a service-account key file ONLY for local testing:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/local-sa-key.json

# Shared Drive *folder* id that output sheets are created in (required).
DRIVE_FOLDER_ID=

# ─── /run auth (Google sign-in from Squarespace) ─────────────────────────────
# OAuth client id of the Google sign-in button; the ID token audience must match.
OAUTH_CLIENT_ID=
# Restrict to your business domain (e.g. abilium.com) + a final allow-list.
ALLOWED_DOMAIN=
ALLOWED_EMAILS=adrianmgarza@gmail.com

# Browser origin(s) allowed to call /run (your Squarespace site).
CORS_ORIGINS=https://www.your-squarespace-site.com

# ─── Options ─────────────────────────────────────────────────────────────────
# Inventory dedupe: "1" to enable (default off; retail values are an upper bound).
INVENTORY_DEDUPE=0

# ─── Monthly summary email (optional; logs if unset) ─────────────────────────
SUMMARY_EMAIL=adrianmgarza@gmail.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
